PORT=3000

# Senha para acessar http://localhost:3000/admin
ADMIN_PASSWORD=admin123

# WhatsApp Cloud API
# Crie um app no Meta for Developers e preencha estes dados.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Numero que vai receber os relatorios, com codigo do pais e DDD.
# Exemplo: 5511999999999
WHATSAPP_TO=

# Em desenvolvimento, deixe como true para testar sem enviar WhatsApp real.
WHATSAPP_DRY_RUN=true

# Google Drive via Google Apps Script - opcional.
GOOGLE_APPS_SCRIPT_URL=
GOOGLE_DRIVE_UPLOAD_SECRET=troque-esta-chave

# true = nao envia arquivo ao Drive, apenas salva o fluxo no terminal.
GOOGLE_DRIVE_DRY_RUN=true
